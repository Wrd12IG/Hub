# WRDigital HUB - Environment Variables Template
# Copy this file to .env.local and fill in your values

# ─── App ──────────────────────────────────────────────────────────────────────
# Development: http://localhost:9002 | Production: https://your-domain.vercel.app
APP_BASE_URL=http://localhost:9002
NEXT_PUBLIC_API_URL=

# ─── Firebase (Client SDK) ────────────────────────────────────────────────────
# Get from Firebase Console > Project Settings > Your apps
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id

# ─── Firebase Admin SDK ───────────────────────────────────────────────────────
# Get from Firebase Console > Project Settings > Service Accounts > Generate new key
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxx@your-project.iam.gserviceaccount.com
# Keep private key in quotes, preserving \n newlines
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nXXXX\n-----END PRIVATE KEY-----\n"

# ─── Security ─────────────────────────────────────────────────────────────────
# 64-char hex string — generate with: openssl rand -hex 32
ENCRYPTION_KEY=your_64_char_hex_encryption_key

# ─── Automation & Cron ────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
AUTOMATION_SECRET=your_automation_secret
CRON_SECRET=your_cron_secret

# ─── AI APIs ──────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key
ANTHROPIC_API_KEY=your_anthropic_api_key

# ─── Brevo (Email) ────────────────────────────────────────────────────────────
# Get from Brevo Dashboard > SMTP & API
BREVO_API_KEY=your_brevo_api_key
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=your_brevo_smtp_user
SMTP_PASS=your_brevo_smtp_password

# ─── Daily Digest ─────────────────────────────────────────────────────────────
DIGEST_RECIPIENT_EMAIL=digest@example.com
DIGEST_RECIPIENT_NAME=Hub Admin

# ─── Google OAuth + APIs ──────────────────────────────────────────────────────
# Get from Google Cloud Console > APIs & Services > Credentials
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REFRESH_TOKEN=your_google_refresh_token
# Service Account JSON (inline, stringified) for Analytics
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
GOOGLE_ANALYTICS_SERVICE_ACCOUNT_EMAIL=sa@your-project.iam.gserviceaccount.com
GOOGLE_ANALYTICS_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nXXXX\n-----END PRIVATE KEY-----\n"

# ─── Google Ads ───────────────────────────────────────────────────────────────
# Get from Google Ads API Center
GOOGLE_ADS_DEVELOPER_TOKEN=your_google_ads_developer_token
GOOGLE_ADS_MANAGER_ACCOUNT_ID=your_manager_account_id
GOOGLE_ADS_LOGIN_CUSTOMER_ID=your_login_customer_id

# ─── Meta (Facebook) Ads ──────────────────────────────────────────────────────
# System User Token from Meta Business Manager > System Users
META_SYSTEM_USER_TOKEN=your_meta_system_user_token
